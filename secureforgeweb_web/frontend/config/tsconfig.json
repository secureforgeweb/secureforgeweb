{
  "include": ["../src/**/*"],
  "exclude": ["../node_modules", "../dist"],
  "compilerOptions": {
    "incremental": true,
    "tsBuildInfoFile": "../.tsbuildinfo",
    "noEmit": true,
    "module": "ESNext",
    "strict": true,
    "lib": ["esnext", "dom", "dom.iterable"],
    "jsx": "preserve",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "allowImportingTsExtensions": true,
    "moduleResolution": "bundler",
    "baseUrl": "..",
    "types": ["node", "vite/client"],
    "paths": {
      "@/*": ["./src/*"],
      "@shared/*": ["../backend/shared/*"]
    }
  }
}
