# PostgreSQL
DATABASE_URL=postgresql://secureforgeweb_user:secureforgeweb_pass@localhost:5432/secureforgeweb

JWT_SECRET=altere_para_um_segredo_longo_e_aleatorio_minimo_32_caracteres

# URLs (frontend :5173, backend :3000)
PORT=3000
FRONTEND_URL=http://localhost:5173
VITE_API_PROXY_TARGET=http://localhost:3000

# HTTPS local (demo/apresentação) — rode: pnpm https:setup
# VITE_DEV_HTTPS=1
# HTTPS_CERT=certs/localhost.pem
# HTTPS_KEY=certs/localhost-key.pem
# FRONTEND_URL=https://localhost:5173
# VITE_OAUTH_PORTAL_URL=https://localhost:5173/login
# VITE_API_PROXY_TARGET=https://localhost:3000
# ENABLE_SECURE_HEADERS=1
# COOKIE_SECURE=1
# ADDITIONAL_ORIGINS=https://localhost:5173,https://localhost:3000

# App / OAuth (local)
VITE_APP_ID=local
OAUTH_SERVER_URL=http://localhost:3000
VITE_OAUTH_PORTAL_URL=http://localhost:5173/login
OWNER_OPEN_ID=local_admin
OWNER_NAME=Administrador

# Analytics Umami (opcional)
VITE_ANALYTICS_ENDPOINT=
VITE_ANALYTICS_WEBSITE_ID=

# E-mail (opcional — reset de senha)
# RESEND_API_KEY=
# SMTP_HOST=
# SMTP_PORT=
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=

# Assistente IA — configurado por usuário em /profile/ai-assistant
# (não é necessário configurar no .env; linhas abaixo são legado/opcional)
# AI_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o-mini
# OPENAI_BASE_URL=https://api.openai.com/v1
# AI_ASSISTANT_ENABLED=true

# Segurança (produção)
# TRUST_PROXY=1
# FORCE_HTTPS=1
# COOKIE_SECURE=1
# LINK_IN_BAND_RESET=0
